{
  "manifest_version": 3,
  "name": "Screen Pet - 화면 펫",
  "version": "1.1.0",
  "description": "화면을 뛰어다니는 귀여운 펫 친구! 고양이 🐱 강아지 🐶 햄스터 🐹 중 선택 가능",
  "permissions": ["storage", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "펫 선택",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["pets.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
